{
  "name": "signalwebapp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A local web UI for Signal Desktop, bridged via the Chrome DevTools Protocol. Run Signal as a browser tab.",
  "scripts": {
    "start": "node src/server.js",
    "launch-signal": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/launch-signal.ps1",
    "autostart": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/autostart.ps1",
    "autostart:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-autostart.ps1",
    "autostart:remove": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-autostart.ps1 -Uninstall",
    "dev": "node --watch src/server.js"
  },
  "engines": {
    "node": ">=22"
  }
}
