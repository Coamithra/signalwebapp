# Copy this file to `.env` (which is gitignored) and fill in your values.
# The server loads `.env` from the repo root automatically on startup, so you
# don't have to set these in your shell. Format is KEY=value, one per line —
# no spaces around `=`, no quotes needed.

# Giphy API key for the /gif picker. Get a free one at https://developers.giphy.com
# (sign in, Create an App, choose "API"). Without it, the picker just shows a
# "set your key" hint instead of GIFs.
GIPHY_API_KEY=

# Optional: max content rating for GIF results (g, pg, pg-13, r). Default: g
#GIPHY_RATING=g
