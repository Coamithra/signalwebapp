# Copy this file to `.env` (which is gitignored) and fill in your values.
# The server loads `.env` from the repo root automatically on startup, so you
# don't have to set these in your shell. Format is KEY=value, one per line —
# no spaces around `=`, no quotes needed.

# Giphy API key for the /gif picker. Get a free one at https://developers.giphy.com
# (sign in, Create an App, choose "API"). Without it, the picker just shows a
# "set your key" hint instead of GIFs.
GIPHY_API_KEY=

# Optional: max content rating for GIF results (g, pg, pg-13, r). Default: g
#GIPHY_RATING=g

# Google Gemini API key for auto-TLDR of YouTube links. Get one at
# https://aistudio.google.com/apikey . When set, you can enable "Auto-TLDR
# YouTube links" per chat (thread header -> options menu): links you post in an
# enabled chat get a short auto-summary. Without it, the toggle shows a hint.
# GOOGLE_API_KEY (Google's own SDK name) is accepted too, so set either one.
GEMINI_API_KEY=

# Optional: which Gemini model generates the summary. Default: gemini-2.5-flash
#GEMINI_MODEL=gemini-2.5-flash

# Optional: the transcript is fetched directly (zero-dep). If YouTube bot-gates
# that and yt-dlp (https://github.com/yt-dlp/yt-dlp) is installed on PATH, it's
# used as a fallback. Set TLDR_YTDLP=0 to disable that fallback (never spawn it).
#TLDR_YTDLP=1
